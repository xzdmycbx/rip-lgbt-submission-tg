# Public hostname / URL of the deployment. Used to derive the
# WebAuthn relying-party ID and to produce TG one-shot login links.
SITE_URL=http://localhost:8080

# Initial superadmin username. Will be created on first launch with the
# password from .secrets/superadmin_password (mounted via docker secret).
SUPERADMIN_USERNAME=admin

# Override the host port if 8080 is already in use.
HOST_PORT=8080

# Container timezone.
TZ=Asia/Shanghai
